# HuggingFace Token (Required)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# OpenAI API Key (Required)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Modal.com Tokens (Optional - for serverless deployment)
# Get from: https://modal.com/settings
MODAL_TOKEN_ID=your_modal_token_id_here
MODAL_TOKEN_SECRET=your_modal_token_secret_here

# Pushover (Optional - for push notifications)
# Get from: https://pushover.net/
PUSHOVER_USER=your_pushover_user_here
PUSHOVER_TOKEN=your_pushover_token_here

# Configuration
LITE_MODE=False  # Set to True for faster testing with smaller dataset
USE_MODAL=False  # Set to True to use Modal.com for SpecialistAgent
ENABLE_NOTIFICATIONS=False  # Set to True to enable push notifications

# Model Settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FRONTIER_MODEL=gpt-5.1
SPECIALIST_MODEL=meta-llama/Llama-3.2-3B

# RAG Settings
VECTOR_DB_PATH=./data/products_vectorstore
TOP_K_SIMILAR=5

# Ensemble Settings
USE_CONFIDENCE_WEIGHTING=True  # Our improvement!
DEFAULT_FRONTIER_WEIGHT=0.8
DEFAULT_SPECIALIST_WEIGHT=0.1
DEFAULT_NEURAL_WEIGHT=0.1
