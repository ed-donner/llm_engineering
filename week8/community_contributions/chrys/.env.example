# ARIA — Market Intelligence & Alert System
# Copy to .env and fill in your keys.

# Pushover (required for alerts)
PUSHOVER_USER=your_pushover_user_key
PUSHOVER_TOKEN=your_pushover_app_token

# Data sources (at least one for stocks/indices, one for commodities, one for crypto)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
# CommodityPriceAPI for gold/silver (https://commoditypriceapi.com)
COMMODITY_PRICE_API_KEY=your_commodity_price_api_key

# News and LLM (sentiment via OpenRouter)
NEWSAPI_KEY=your_newsapi_key
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional: override watchlist (comma-separated symbols)
# ARIA_WATCHLIST=XAU/USD,AAPL,BTC/USD

# Optional: LLM model for sentiment (default: openrouter/openai/gpt-4o-mini)
# ARIA_SENTIMENT_MODEL=openrouter/openai/gpt-4o-mini
