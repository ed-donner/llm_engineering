 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# The Analogous Learnings Daily Briefer\n",
    "\n",
    "This is my Week 8 Capstone Project. It autonomously scans tech news, uses a Modal-deployed RAG pipeline to explain complex tech concepts using Football analogies, and then texts that analogy to my phone using Pushover."
   ],
   "id": "a44b01345cc21ff"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-09T13:28:55.998902Z",
     "start_time": "2026-03-09T13:28:55.977657Z"
    }
   },
   "source": [
    "import json\n",
    "from dotenv import load_dotenv\n",
    "from openai import OpenAI\n",
    "import gradio as gr\n",
    "\n",
    "from week8.community_contributions.toluwalemi.agents.scanner import ScannerAgent\n",
    "from week8.community_contributions.toluwalemi.agents.analyzer import AnalyzerAgent\n",
    "from week8.community_contributions.toluwalemi.agents.messenger import MessengerAgent\n",
    "\n",
    "load_dotenv(override=True)\n",
    "openai = OpenAI()\n",
    "MODEL = \"gpt-4o-mini\""
   ],
   "id": "4ca1049ca63497d7",
   "outputs": [],
   "execution_count": 15
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## Initialize Agents and Tools",
   "id": "4e990d715f0124fd"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-09T13:28:58.298560Z",
     "start_time": "2026-03-09T13:28:58.290890Z"
    }
   },
   "source": [
    "scanner = ScannerAgent(count=3)\n",
    "analyzer = AnalyzerAgent()\n",
    "messenger = MessengerAgent()\n",
    "\n",
    "def scan_tech_news() -> str:\n",
    "    return scanner.scan()\n",
    "\n",
    "def explain_with_football(tech_concept: str) -> str:\n",
    "    return analyzer.analyze(tech_concept)\n",
    "\n",
    "def notify_user(title: str, analogy_explanation: str) -> str:\n",
    "    return messenger.push(title, analogy_explanation)\n"
   ],
   "id": "7da16b72aa59471a",
   "outputs": [],
   "execution_count": 16
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-09T13:29:00.907923Z",
     "start_time": "2026-03-09T13:29:00.899233Z"
    }
   },
   "source": [
    "scan_tool = {\n",
    "    \"name\": \"scan_tech_news\",\n",
    "    \"description\": \"Returns top tech news articles scraped from the internet\",\n",
    "    \"parameters\": {\n",
    "        \"type\": \"object\",\n",
    "        \"properties\": {},\n",
    "        \"required\": [],\n",
    "        \"additionalProperties\": False\n",
    "    }\n",
    "}\n",
    "\n",
    "explain_tool = {\n",
    "    \"name\": \"explain_with_football\",\n",
    "    \"description\": \"Given a complex tech concept or news headline, use a RAG pipeline to explain it using a grounded football analogy\",\n",
    "    \"parameters\": {\n",
    "        \"type\": \"object\",\n",
    "        \"properties\": {\n",
    "            \"tech_concept\": {\n",
    "                \"type\": \"string\",\n",
    "                \"description\": \"The tech headline or concept to be explained\"\n",
    "            }\n",
    "        },\n",
    "        \"required\": [\"tech_concept\"],\n",
    "        \"additionalProperties\": False\n",
    "    }\n",
    "}\n",
    "\n",
    "notify_tool = {\n",
    "    \"name\": \"notify_user\",\n",
    "    \"description\": \"Send the user a push notification summarizing the tech concept via the football analogy\",\n",
    "    \"parameters\": {\n",
    "        \"type\": \"object\",\n",
    "        \"properties\": {\n",
    "            \"title\": {\n",
    "                \"type\": \"string\",\n",
    "                \"description\": \"A snappy title combining the tech concept and football\"\n",
    "            },\n",
    "            \"analogy_explanation\": {\n",
    "                \"type\": \"string\",\n",
    "                \"description\": \"The generated explanation of the tech concept via football\"\n",
    "            }\n",
    "        },\n",
    "        \"required\": [\"title\", \"analogy_explanation\"],\n",
    "        \"additionalProperties\": False\n",
    "    }\n",
    "}\n",
    "\n",
    "tools = [\n",
    "    {\"type\": \"function\", \"function\": scan_tool},\n",
    "    {\"type\": \"function\", \"function\": explain_tool},\n",
    "    {\"type\": \"function\", \"function\": notify_tool}\n",
    "]"
   ],
   "id": "3363b7a84fda1ed5",
   "outputs": [],
   "execution_count": 17
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## The Orchestrator\n",
    "\n",
    "Run until all tools execute."
   ],
   "id": "b0123e1d656b253b"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-09T13:29:04.602413Z",
     "start_time": "2026-03-09T13:29:04.593321Z"
    }
   },
   "source": "TOOL_DISPATCH = {\n    \"scan_tech_news\": scan_tech_news,\n    \"explain_with_football\": explain_with_football,\n    \"notify_user\": notify_user,\n}\n\ndef handle_tool_call(message, status_update):\n    results = []\n    for tool_call in message.tool_calls:\n        tool_name = tool_call.function.name\n        arguments = json.loads(tool_call.function.arguments)\n\n        status_update(f\"Executing Tool: {tool_name} with args {str(arguments)[:50]}...\")\n\n        tool = TOOL_DISPATCH.get(tool_name)\n        if tool is None:\n            result = f\"Error: Unknown tool '{tool_name}'\"\n        else:\n            result = tool(**arguments)\n\n        results.append({\n            \"role\": \"tool\",\n            \"content\": json.dumps(result),\n            \"tool_call_id\": tool_call.id\n        })\n    return results\n\ndef run_autonomous_workflow(log_callback):\n    system_message = \"You are an autonomous orchestrator. You find the most complex-sounding tech news article, use your tools to explain it with a football analogy, and push the notification. Return OK when finished.\"\n    user_message = \"Start the complete autonomous workflow now.\"\n\n    messages = [\n        {\"role\": \"system\", \"content\": system_message},\n        {\"role\": \"user\", \"content\": user_message}\n    ]\n\n    log_callback(\"Pipeline Started: LLM planning...\")\n\n    max_iterations = 10\n    output_log = \"\"\n    for _ in range(max_iterations):\n        response = openai.chat.completions.create(model=MODEL, messages=messages, tools=tools)\n\n        if response.choices[0].finish_reason == \"tool_calls\":\n            message = response.choices[0].message\n            results = handle_tool_call(message, log_callback)\n            messages.append(message)\n            messages.extend(results)\n            output_log += f\"Tool returned: {str(results)[:100]}...\\n\"\n        else:\n            output_log += f\"\\nFinal Result: {response.choices[0].message.content}\"\n            log_callback(\"Pipeline Finished!\")\n            break\n    else:\n        output_log += \"\\nWarning: Reached maximum iterations without completing.\"\n        log_callback(\"Pipeline stopped: max iterations reached.\")\n\n    return output_log",
   "id": "d5f598b4abce30b9",
   "outputs": [],
   "execution_count": 18
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## The UI Dashboard",
   "id": "e6b37165e1bc191f"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-09T13:29:09.345451Z",
     "start_time": "2026-03-09T13:29:09.336577Z"
    }
   },
   "source": "def gradio_run():\n    def execute_btn():\n        yield \"Starting AI sequence...\"\n\n        log_entries = []\n        def log_cb(msg):\n            log_entries.append(msg)\n\n        final_output = run_autonomous_workflow(log_cb)\n        yield \"\\n\".join(log_entries) + \"\\n\\n---\\n\" + final_output\n\n    with gr.Blocks(title=\"Agentic Learnings Updater\") as ui:\n        gr.Markdown('<div style=\"text-align: center;font-size:24px\">Analogous Learnings Daily Briefer</div>')\n        gr.Markdown('<div style=\"text-align: center\">Autonomous agent framework that scans news, translates concepts using RAG on Modal, and alerts you via Pushover.</div>')\n\n        with gr.Row():\n            run_btn = gr.Button(\"Trigger Autonomous Daily Briefing\", variant=\"primary\")\n\n        with gr.Row():\n            output_console = gr.Textbox(label=\"Orchestration Log\", lines=15, interactive=False)\n\n        run_btn.click(execute_btn, inputs=[], outputs=[output_console])\n\n    ui.launch(inbrowser=True)",
   "id": "bd9034f5e304a153",
   "outputs": [],
   "execution_count": 19
  },
  {
