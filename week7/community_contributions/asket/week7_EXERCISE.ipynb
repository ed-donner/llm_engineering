import torch
from datasets import load_dataset, Dataset
from transformers import AutoTokenizer, AutoModelForCausalLM, TrainingArguments, Trainer
from peft import get_peft_model, LoraConfig, TaskType

# Path to your exported training data
jsonl_path = "pricer_train_xof.jsonl"

# Load prompt-completion pairs as Hugging Face dataset
def load_jsonl_for_ft(jsonl_path):
    data = []
    with open(jsonl_path, "r", encoding="utf-8") as f:
        for line in f:
            data.append(json.loads(line.strip()))
    return Dataset.from_list(data)

ft_dataset = load_jsonl_for_ft(jsonl_path)

# Format: instruct fine-tuning (prompt → completion)
def tokenize_function(example):
    return tokenizer(
        example["prompt"],
        text_target=example["completion"], 
        truncation=True,
        padding="max_length",
        max_length=512,
    )

# Use an open-source model checkpoint (change as needed)
base_model_name = "meta-llama/Llama-3-3B"  # Or Llama-3-8B, Mistral, etc.
tokenizer = AutoTokenizer.from_pretrained(base_model_name)
model = AutoModelForCausalLM.from_pretrained(base_model_name, torch_dtype=torch.float16, device_map="auto")

tokenized_dataset = ft_dataset.map(tokenize_function, batched=True)

# QLoRA config (Lightweight PEFT)
lora_config = LoraConfig(
    r=8,
    lora_alpha=16,
    lora_dropout=0.05,
    bias="none",
    task_type=TaskType.CAUSAL_LM
)

peft_model = get_peft_model(model, lora_config)

# Training arguments
training_args = TrainingArguments(
    output_dir="./finetuned_llama_xof",
    num_train_epochs=2,
    per_device_train_batch_size=2,
    gradient_accumulation_steps=2,
    learning_rate=2e-4,
    fp16=True,
    logging_steps=5,
    save_strategy="epoch",
    report_to="none",
)

trainer = Trainer(
    model=peft_model,
    args=training_args,
    train_dataset=tokenized_dataset,
)

# Start fine-tuning
trainer.train()

# Save the adapter (only LoRA weights for lightweight deployment)
peft_model.save_pretrained("./finetuned_llama_xof_adapter")
print("Finished fine-tuning. Saved LoRA adapter weights for open-source deployment.")

